# UniAudit Outreach Toolkit — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------------------------------------------------------
# UniAudit API
# ----------------------------------------------------------------------------

# URL of the running UniAudit backend (local VM or remote)
UNIAUDIT_API_URL=http://your-vm-ip:8000

# Base URL for public audit report links (sent to prospects)
REPORT_BASE_URL=https://uni-audit.vercel.app/university

# ----------------------------------------------------------------------------
# Azure OpenAI — required for generate_email.py AI copy generation
# ----------------------------------------------------------------------------

# Your Azure OpenAI resource endpoint
# Format: https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI API key (from Azure Portal > Keys and Endpoint)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# The deployment name you created in Azure AI Studio (e.g. gpt-4o, gpt-4-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version — check Azure docs for latest stable version
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ----------------------------------------------------------------------------
# SMTP — for sending emails directly via generate_email.py --send
# ----------------------------------------------------------------------------

# Gmail example: use smtp.gmail.com with an App Password (not your main password)
# To create a Gmail App Password: myaccount.google.com/apppasswords
# Outlook/365: smtp.office365.com, port 587
# Custom SMTP relay: use your provider's settings

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password-here

# Sender identity shown to recipients
FROM_NAME=Your Full Name
FROM_EMAIL=your@email.com

# ----------------------------------------------------------------------------
# Scheduling / calendar
# ----------------------------------------------------------------------------

# Your Calendly (or Cal.com, Savvycal, etc.) booking link
# Used in follow-up emails and LinkedIn DMs
CALENDAR_LINK=https://calendly.com/your-link/15min

# ----------------------------------------------------------------------------
# Optional: SendGrid (alternative to SMTP)
# Uncomment and use with a custom sender class if preferred
# ----------------------------------------------------------------------------

# SENDGRID_API_KEY=SG.your-sendgrid-key-here

# ----------------------------------------------------------------------------
# Optional: Lemlist / Instantly / Smartlead
# If using a dedicated cold email platform, export the generated .txt files
# and import them as templates. No additional env vars needed for that workflow.
# ----------------------------------------------------------------------------
